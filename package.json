{
  "name": "@skalenetwork/bite",
  "version": "0.8.2",
  "description": "TS Library to interact with BITE protocol",
  "homepage": "https://github.com/skalenetwork/bite.ts",
  "license": "LGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "yarn clean && tsup --env.NODE_ENV production",
    "build:dev": "yarn clean && tsup --env.NODE_ENV development",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint ./src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint ./src --ext .ts --fix",
    "version": "node -e \"console.log(require('./package.json').version);\"",
    "smoke:node": "node scripts/env-smoke/node-smoke.mjs",
    "smoke:node:cjs": "node scripts/env-smoke/node-smoke.cjs",
    "smoke:web:install": "npm --prefix scripts/env-smoke/web install",
    "smoke:web:build": "npm --prefix scripts/env-smoke/web run build",
    "smoke:web:runtime": "npm --prefix scripts/env-smoke/web run runtime",
    "smoke:web:dev": "npm --prefix scripts/env-smoke/web run dev",
    "smoke:worker:install": "npm --prefix scripts/env-smoke/worker install",
    "smoke:worker:dry": "npm --prefix scripts/env-smoke/worker run deploy:dry",
    "smoke:worker:runtime": "npm --prefix scripts/env-smoke/worker run runtime",
    "smoke:worker:dev": "npm --prefix scripts/env-smoke/worker run dev",
    "smoke:bun": "bun scripts/env-smoke/bun-smoke.mjs",
    "smoke:deno": "deno run --allow-read --allow-env --node-modules-dir=auto scripts/env-smoke/deno-smoke.ts"
  },
  "keywords": [
    "SKALE",
    "blockchain",
    "BITE",
    "threshold",
    "cryptography",
    "encryption"
  ],
  "dependencies": {
    "@ethereumjs/rlp": "10.0.0",
    "@skalenetwork/t-encrypt": "0.8.0-develop.0",
    "tslog": "^4.9.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^8.45.0",
    "ethers": "^6.13.5",
    "tsup": "^7.2.0",
    "typescript": "^5.3.0"
  }
}
